# ============================================================
# VisualRoad Data Lake - .env.example
# Copiar a .env para ejecutar los jobs localmente.
# No incluir valores reales de infraestructura si este fichero se publica.
# Usar placeholders y completar el .env local con los valores reales.
# ============================================================

# --- Proyecto / region ---
# Proyecto donde viven buckets, BigQuery y Vertex AI.
GCP_PROJECT_ID=your-gcp-project-id

# Region para operaciones regionales de GCP.
GCP_REGION=your-gcp-region

# --- Vertex AI / Gemini ---
# Region del endpoint de Gemini en Vertex AI.
VERTEX_LOCATION=your-vertex-location

# Modelo Gemini usado por privacy (si ANON_METHOD=gemini) y classify.
GEMINI_MODEL=gemini-model-name

# (Opcional) WORKERS: concurrencia de un job. El valor por defecto vive en el CODIGO
# y es POR JOB (classify=4 por la cuota de Gemini; ingest-public=16, I/O de GCS/BQ).
# NO lo pongas en el env compartido del deploy: acoplaria todos los jobs al mismo
# valor. Descomenta solo para un run local puntual (lo leeria el job que ejecutes).
# WORKERS=4

# --- Anonimizacion (privacy) ---
# Backend de anonimizacion: gemini | vision | detector.
ANON_METHOD=gemini

# --- Buckets (GCS) ---
# Publico crudo; ingest lee de aqui.
BKT_RAW_PUBLIC=your-raw-public-bucket

# Publico normalizado; ingest escribe aqui y classify lo lee.
BKT_PUBLIC=your-public-normalized-bucket

# Crudo de usuario; privacy lee de aqui.
BKT_RAW_USER=your-raw-user-bucket

# Usuario limpio; privacy escribe aqui y classify lo lee.
BKT_USER_CLEAN=your-clean-user-bucket

# Carpeta de los <dataset>.yml en raw-public; ingest lee descriptors de aqui.
DESCRIPTORS_PREFIX=_descriptors/

# --- BigQuery ---
# Region de los datasets de BigQuery.
BQ_LOCATION=your-bigquery-location

# Nombres de datasets de BigQuery.
BQ_DS_RAW_METADATA=your_raw_metadata_dataset
BQ_DS_LABEL_REVIEW=your_label_review_dataset
BQ_DS_CLASSIFICATION=your_classification_dataset

# Catalogo de imagenes; ingest y privacy escriben, classify lee.
BQ_TBL_IMAGES=your_images_table

# Versiones de datasets publicos; ingest escribe.
BQ_TBL_SOURCE_DATASETS=your_source_datasets_table

# Auditoria de anonimizacion; privacy escribe.
BQ_TBL_PRIVACY=your_privacy_audit_table

# Cola de revision; privacy escribe frames de baja confianza.
BQ_TBL_LABEL_REVIEW=your_label_review_table

# Clasificacion por imagen; classify escribe.
BQ_TBL_CLASSIFICATIONS=your_classifications_table

# --- Parametros de pipeline ---
# Informativo/sanity; el borrado real lo hace el lifecycle del bucket raw-user.
RAW_USER_TTL_HOURS=24

# Umbral de baja confianza para mandar un frame de usuario a revision.
CONF_THRESHOLD=0.40
